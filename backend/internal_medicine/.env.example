# Path to your knowledge base (JSON or JSONL)
KB_FILE=data/kb.json

# For very large KBs, set this high to avoid the default safety cap.
# The loader stops at EOF, so an over-estimate is fine.
# KB_MAX_DOCS=999999999

# Embeddings + FAISS index storage
EMBEDDINGS_DIR=storage/embeddings

# Embeddings model
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Optional: embedding batch size during indexing (higher can be faster but uses more RAM)
# EMBED_BATCH_SIZE=64

# Ollama
OLLAMA_HOST=http://localhost:11434
# Replace google/flan-t5-base with Ollama phi 2.7B (set to whatever you pulled)
OLLAMA_GENERATOR_MODEL=phi:2.7b
# Separate judge model (can be same)
OLLAMA_JUDGE_MODEL=phi:2.7b

# LLM-as-Judge backend
# Default is Ollama. To use Hugging Face Flan-T5 as judge, set:
#   JUDGE_BACKEND=hf
#   HF_JUDGE_MODEL=google/flan-t5-base
#   HF_JUDGE_MAX_NEW_TOKENS=32
JUDGE_BACKEND=ollama
HF_JUDGE_MODEL=google/flan-t5-base
HF_JUDGE_MAX_NEW_TOKENS=32

# CPU by default on Windows
TRANSFORMERS_DEVICE=-1

# Feature toggles
ENABLE_DOMAIN_GATE=true
ENABLE_NER=true
ENABLE_NLI=true
